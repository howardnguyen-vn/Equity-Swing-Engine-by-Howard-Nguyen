RelaySetup cand = EMPTY
bool baseOk = chopOk and liqOk and gapOk
if bar_index > 250 and baseOk and pivH.size() >= 2 and pivL.size() >= 2
    cand := f_pickBest(cand, detectDoubleForm())
    cand := f_pickBest(cand, detectHsForm())
    cand := f_pickBest(cand, detectTriangleForm())
    cand := f_pickBest(cand, detectFlagForm())
    cand := f_pickBest(cand, detectWedgeForm())

if cand.active and cand.completion < minFormPct
    cand := EMPTY
if cand.active and cashLongOnly and not showBearRisk and not cand.isBull
    cand := EMPTY
if cand.active and cand.phase == "FIRED" and blockLimitFire and not limitOk
    cand := EMPTY
if cand.active and cand.phase == "FIRED" and useBreakVol and volRatio < firedVolMin
    cand := EMPTY
if cand.active and cand.phase == "FIRED" and requireHtfFire
    if cand.isBull and not htfBull
        cand := EMPTY
    if not cand.isBull and not htfBear
        cand := EMPTY
if cand.active and cand.phase == "FIRED" and requireMarketFire and marketValid
    if cand.isBull and not marketBull
        cand := EMPTY
    if not cand.isBull and not marketBear
        cand := EMPTY
if cand.active and cand.phase == "FIRED" and f_rr(cand.entry, cand.stop, cand.tp2) < minRR
    cand := EMPTY
int candConf = f_conf(cand)
if cand.active and candConf < minConf
    cand := EMPTY

var int lastFireBar = na
var string lastKey = ""
string candKey = cand.active ? cand.name + cand.phase + str.tostring(cand.startBar) : ""
bool newEvent = cand.active and barstate.isconfirmed and candKey != lastKey and (na(lastFireBar) or bar_index - lastFireBar >= cooldown)

if newEvent
    lastKey := candKey
    if cand.phase == "FIRED"
        lastFireBar := bar_index

    f_clearDrawings()
    DrawBundle db = DrawBundle.new(array.new_line(), array.new_label(), array.new_box())
    bool tradeLevelsOk = cand.isBull or allowShorts

    dName := cand.name
    dPhase := cand.phase
    dBull := cand.isBull
    dComp := cand.completion
    dNeck := cand.neck
    dEntry := cand.phase == "FIRED" ? (tradeLevelsOk ? cand.entry : cand.neck) : na
    dStop := cand.phase == "FIRED" and tradeLevelsOk ? cand.stop : na
    dTp2 := cand.phase == "FIRED" and tradeLevelsOk ? cand.tp2 : na
    dTp1 := cand.phase == "FIRED" and tradeLevelsOk ? f_tp1(cand.entry, cand.tp2, cand.isBull) : na
    dConf := candConf
    dLastBar := bar_index

    color pc = f_phaseColor(cand.phase)
    color bc = cand.isBull ? colBull : colBear
    color entryCol = cand.isBull ? colBullBr : colBearBr

    if showFormBox
        box bx = box.new(cand.startBar, cand.isBull ? cand.neck : cand.neck + cand.height,
          cand.endBar, cand.isBull ? cand.neck + cand.height : cand.neck,
          border_color=color.new(pc, 40), bgcolor=color.new(pc, 88))
        array.push(db.boxes, bx)

    if showNeck
        line ln = line.new(cand.startBar, cand.neck, cand.endBar + 30, cand.neck,
          color=color.new(pc, 0), width=2, style=line.style_solid)
        array.push(db.lns, ln)

    if showPhaseLbl
        string lblTxt = cand.name + "\n" + cand.phase + " " + str.tostring(cand.completion, "#") + "%"
        label lb = label.new(cand.endBar, cand.neck, lblTxt,
          color=color.new(colDashBg, 10), textcolor=pc,
          style=cand.isBull ? label.style_label_up : label.style_label_down, size=size.small)
        array.push(db.lbls, lb)

    if showFiredLvls and cand.phase == "FIRED"
        int x1 = bar_index
        int x2 = bar_index + 50
        int lx = x2 + 1
        if tradeLevelsOk
            float tp1v = f_tp1(cand.entry, cand.tp2, cand.isBull)
            line le = line.new(x1, cand.entry, x2, cand.entry, color=entryCol, style=line.style_dashed)
            line ls = line.new(x1, cand.stop, x2, cand.stop, color=colSlLine, style=line.style_dashed)
            line l1 = line.new(x1, tp1v, x2, tp1v, color=colTp1Line, style=line.style_dotted)
            line l2 = line.new(x1, cand.tp2, x2, cand.tp2, color=colTp2Line, style=line.style_dashed, width=2)
            array.push(db.lns, le)
            array.push(db.lns, ls)
            array.push(db.lns, l1)
            array.push(db.lns, l2)
            label lbe = label.new(lx, cand.entry, f_levelTitle(cand.isBull) + " " + str.tostring(cand.entry, format.mintick),
              style=label.style_label_left, color=color.new(colDashBg, 25), textcolor=entryCol, size=size.tiny)
            label lbs = label.new(lx, cand.stop, "SL " + str.tostring(cand.stop, format.mintick),
              style=label.style_label_left, color=color.new(colDashBg, 25), textcolor=colSlLine, size=size.tiny)
            label lb1 = label.new(lx, tp1v, "TP1 " + str.tostring(tp1v, format.mintick),
              style=label.style_label_left, color=color.new(colDashBg, 25), textcolor=colTp1Line, size=size.tiny)
            label lb2 = label.new(lx, cand.tp2, "TP2 " + str.tostring(cand.tp2, format.mintick) + "  R:R " + str.tostring(f_rr(cand.entry, cand.stop, cand.tp2), "#.##"),
              style=label.style_label_left, color=color.new(colDashBg, 25), textcolor=colTp2Line, size=size.tiny)
            array.push(db.lbls, lbe)
            array.push(db.lbls, lbs)
            array.push(db.lbls, lb1)
            array.push(db.lbls, lb2)
        else
            line lr = line.new(x1, cand.neck, x2, cand.neck, color=colBearBr, style=line.style_dashed, width=2)
            array.push(db.lns, lr)
            label lbr = label.new(lx, cand.neck, "RISK LEVEL " + str.tostring(cand.neck, format.mintick),
              style=label.style_label_left, color=color.new(colDashBg, 25), textcolor=colBearBr, size=size.tiny)
            array.push(db.lbls, lbr)

    if alertEn and cand.phase == "FIRED"
        string js = '{"source":"Howard Nguyen RELAY VN","phase":"FIRED","pattern":"' + cand.name +
             '","bias":"' + f_biasText(cand.isBull) +
             '","completion":' + str.tostring(cand.completion)
        if tradeLevelsOk
            float tp1vAlert = f_tp1(cand.entry, cand.tp2, cand.isBull)
            js := js + ',"entry":' + str.tostring(cand.entry, format.mintick) +
              ',"tp1":' + str.tostring(tp1vAlert, format.mintick) +
              ',"tp2":' + str.tostring(cand.tp2, format.mintick) +
              ',"sl":' + str.tostring(cand.stop, format.mintick)
        else
            js := js + ',"riskLevel":' + str.tostring(cand.neck, format.mintick)
        js := js + ',"confluence":' + str.tostring(candConf) +
          ',"avgValueB":' + str.tostring(avgValue / 1000000000.0, "#.##") +
          ',"volRatio":' + str.tostring(volRatio, "#.##") + '}'
        alert(js, alert.freq_once_per_bar_close)

    array.push(history, db)

int dAge = dLastBar > 0 ? bar_index - dLastBar : 0
bool dTradeLevel = dPhase == "FIRED" and (dBull or allowShorts)
bool expiredByAge = dPhase == "FIRED" and dAge > expireFiredBars
bool expiredByDistance = dTradeLevel and useEntryGuard and not na(dEntry) and math.abs(dEntry) > 0 and math.abs(close - dEntry) / math.abs(dEntry) > maxEntryDrift
bool expiredByStop = dTradeLevel and not na(dStop) and ((dBull and close < dStop) or (not dBull and close > dStop))

if expiredByAge or expiredByDistance or expiredByStop
    f_clearDrawings()
    dPhase := "EXPIRED"
    dEntry := na
    dStop := na
    dTp1 := na
    dTp2 := na
    dConf := 0

