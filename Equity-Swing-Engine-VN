// =============================================================================
//  TYPES
// =============================================================================
type Pivot
    float p
    int   i

type RelaySetup
    bool   active
    string name
    string phase
    bool   isBull
    float  completion
    float  neck
    float  height
    float  entry
    float  stop
    float  tp2
    int    startBar
    int    endBar
    int    conf

type DrawBundle
    line[]  lns
    label[] lbls
    box[]   boxes

// =============================================================================
//  STATE
// =============================================================================
var RelaySetup EMPTY = RelaySetup.new(false, "", "", false, 0, na, na, na, na, na, na, na, 0)
var array<Pivot> pivH = array.new<Pivot>()
var array<Pivot> pivL = array.new<Pivot>()
var array<DrawBundle> history = array.new<DrawBundle>()

var string dName = "-"
var string dPhase = "IDLE"
var bool   dBull = false
var float  dComp = 0.0
var float  dNeck = na
var float  dEntry = na
var float  dStop = na
var float  dTp1 = na
var float  dTp2 = na
var int    dConf = 0
var int    dLastBar = 0

// =============================================================================
//  CORE SERIES
// =============================================================================
atrVal = ta.atr(atrLen)
volMa  = ta.sma(volume, volLen)
volRatio = volMa > 0 ? volume / volMa : 0.0

float ciSum = math.sum(ta.atr(1), chopLen)
float ciHl  = ta.highest(high, chopLen) - ta.lowest(low, chopLen)
float chopIdx = ciHl > 0 ? 100.0 * math.log10(ciSum / ciHl) / math.log10(chopLen) : 50.0
bool chopOk = not useChop or chopIdx < chopMax

f_autoBand() =>
    str.contains(syminfo.tickerid, "UPCOM:") ? 0.15 :
      str.contains(syminfo.tickerid, "HNX:") ? 0.10 : 0.07

float limitBand =
  switch exchangeBand
    "HOSE +/-7%"   => 0.07
    "HNX +/-10%"   => 0.10
    "UPCOM +/-15%" => 0.15
    "Custom"       => customBandPct
    => f_autoBand()

float gapPct = not na(close[1]) and close[1] > 0 ? math.abs(open - close[1]) / close[1] : 0.0
float dayMovePct = not na(close[1]) and close[1] > 0 ? math.abs(close - close[1]) / close[1] : 0.0
bool nearLimitBar = dayMovePct >= limitBand * limitHitRatio
bool limitOk = not blockLimitFire or not nearLimitBar
bool gapOk = not useGapFilter or gapPct <= maxGapPct

float tradeValue = volume * close * valuePriceMult
float avgValue = ta.sma(tradeValue, liqLen)
bool liqOk = not useLiquidity or avgValue >= minAvgValueB * 1000000000.0

htfClose = request.security(syminfo.tickerid, htfTf, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htfFastE = request.security(syminfo.tickerid, htfTf, ta.ema(close, htfFast), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htfSlowE = request.security(syminfo.tickerid, htfTf, ta.ema(close, htfSlow), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htfBull  = htfFastE > htfSlowE and htfClose > htfFastE
htfBear  = htfFastE < htfSlowE and htfClose < htfFastE

marketClose = request.security(marketSymbol, marketTf, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
marketFastE = request.security(marketSymbol, marketTf, ta.ema(close, marketFast), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
marketSlowE = request.security(marketSymbol, marketTf, ta.ema(close, marketSlow), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
marketValid = not na(marketClose) and not na(marketFastE) and not na(marketSlowE)
marketBull  = marketValid and marketFastE > marketSlowE and marketClose > marketFastE
marketBear  = marketValid and marketFastE < marketSlowE and marketClose < marketFastE

getDashPos(p) =>
    switch p
        "Top Left"     => position.top_left
        "Top Right"    => position.top_right
        "Bottom Left"  => position.bottom_left
        => position.bottom_right

f_near(float a, float b) =>
    math.abs(a - b) <= (a + b) * 0.5 * symTol

f_proj(float x1, float y1, float x2, float y2, int x) =>
    x2 == x1 ? y1 : y1 + (y2 - y1) / (x2 - x1) * (x - x1)

f_rr(float ep, float sl, float tp) =>
    math.abs(ep - sl) > 0 ? math.abs(tp - ep) / math.abs(ep - sl) : 0.0

f_tp1(float ep, float tp2, bool bull) =>
    float d = math.abs(tp2 - ep)
    bull ? ep + d * tp1Pct : ep - d * tp1Pct

f_biasText(bool bull) =>
    bull ? "long" : allowShorts ? "short" : "risk_off"

f_levelTitle(bool bull) =>
    bull ? "ENTRY" : allowShorts ? "SHORT ENTRY" : "RISK LEVEL"

f_phaseColor(string ph) =>
    ph == "FIRED" ? colFired : ph == "ARMED" ? colArmed : ph == "EXPIRED" ? colNeutral : colForm

f_conf(RelaySetup s) =>
    if not s.active
        0
    else
        int sc = 0
        sc += s.completion >= 85 ? 2 : s.completion >= minFormPct ? 1 : 0
        sc += useHtf ? (s.isBull and htfBull ? 2 : not s.isBull and htfBear ? 2 : 0) : 1
        sc += useMarket ? (marketValid ? (s.isBull and marketBull ? 2 : not s.isBull and marketBear ? 2 : 0) : 1) : 1
        sc += chopOk ? 1 : 0
        sc += liqOk ? 1 : 0
        sc += gapOk ? 1 : 0
        sc += s.phase == "FIRED" ? 2 : s.phase == "ARMED" ? 1 : 0
        sc += s.phase == "FIRED" ? (useBreakVol and volRatio >= firedVolMin ? 2 : useBreakVol ? 0 : 1) :
          (useVolCoil and volMa > 0 and volume <= volMa * volCoilMax ? 1 : 0)
        sc += f_rr(s.entry, s.stop, s.tp2) >= minRR ? 1 : 0
        sc += s.height >= atrVal * 2.0 ? 1 : 0
        sc -= s.phase == "FIRED" and blockLimitFire and nearLimitBar ? 2 : 0
        math.max(0, math.min(sc, 10))

f_clearDrawings() =>
    for b in history
        for ln in b.lns
            if not na(ln)
                line.delete(ln)
        for lb in b.lbls
            if not na(lb)
                label.delete(lb)
        for bx in b.boxes
            if not na(bx)
                box.delete(bx)
    array.clear(history)

// =============================================================================
//  PIVOT COLLECTION
// =============================================================================
float ph = ta.pivothigh(high, pivLen, pivLen)
float pl = ta.pivotlow(low, pivLen, pivLen)
if not na(ph)
    pivH.unshift(Pivot.new(ph, bar_index - pivLen))
    if pivH.size() > maxPivots
        pivH.pop()
if not na(pl)
    pivL.unshift(Pivot.new(pl, bar_index - pivLen))
    if pivL.size() > maxPivots
        pivL.pop()

// =============================================================================
//  FORMATION SCANNERS
// =============================================================================
detectDoubleForm() =>
    RelaySetup s = EMPTY
    if pivH.size() >= 2 and pivL.size() >= 1 and enDouble
        Pivot p1 = pivH.get(0)
        Pivot p2 = pivH.get(1)
        Pivot mid = pivL.get(0)
        if p1.i > mid.i and mid.i > p2.i and f_near(p1.p, p2.p)
            float neck = mid.p
            float h = (p1.p + p2.p) * 0.5 - neck
            if h > atrVal
                float comp = 70.0
                comp += close < neck ? 15.0 : 0.0
                comp += math.abs(close - neck) <= atrVal * armedAtr ? 15.0 : 0.0
                bool fired = close < neck - atrVal * brkAtr
                string pstate = fired ? "FIRED" : math.abs(close - neck) <= atrVal * armedAtr ? "ARMED" : "FORMING"
                float ep = close
                float tp2 = neck - h
                float sl = ep + math.abs(tp2 - ep) * slPctTgt
                s := RelaySetup.new(true, "Double Top", pstate, false, comp, neck, h, ep, sl, tp2, p2.i, bar_index, 0)
    if not s.active and pivL.size() >= 2 and pivH.size() >= 1 and enDouble
        Pivot p1 = pivL.get(0)
        Pivot p2 = pivL.get(1)
        Pivot mid = pivH.get(0)
        if p1.i > mid.i and mid.i > p2.i and f_near(p1.p, p2.p)
            float neck = mid.p
            float h = neck - (p1.p + p2.p) * 0.5
            if h > atrVal
                float comp = 70.0
                comp += close > neck ? 15.0 : 0.0
                comp += math.abs(close - neck) <= atrVal * armedAtr ? 15.0 : 0.0
                bool fired = close > neck + atrVal * brkAtr
                string pstate = fired ? "FIRED" : math.abs(close - neck) <= atrVal * armedAtr ? "ARMED" : "FORMING"
                float ep = close
                float tp2 = neck + h
                float sl = ep - math.abs(tp2 - ep) * slPctTgt
                s := RelaySetup.new(true, "Double Bottom", pstate, true, comp, neck, h, ep, sl, tp2, p2.i, bar_index, 0)
    s

detectHsForm() =>
    RelaySetup s = EMPTY
    if pivH.size() >= 3 and pivL.size() >= 2 and enHs
        Pivot rs = pivH.get(0)
        Pivot head = pivH.get(1)
        Pivot ls = pivH.get(2)
        Pivot nl = pivL.get(1)
        Pivot nr = pivL.get(0)
        if head.p > rs.p and head.p > ls.p and f_near(rs.p, ls.p)
            float neck = f_proj(nl.i, nl.p, nr.i, nr.p, bar_index)
            float h = head.p - (nl.p + nr.p) * 0.5
            if h > atrVal
                float comp = 65.0
                comp += close < neck ? 12.0 : 0.0
                comp += math.abs(close - neck) <= atrVal * armedAtr ? 18.0 : 0.0
                string pstate = close < neck - atrVal * brkAtr ? "FIRED" : math.abs(close - neck) <= atrVal * armedAtr ? "ARMED" : "FORMING"
                float ep = close
                float tp2 = neck - h
                float sl = ep + math.abs(tp2 - ep) * slPctTgt
                s := RelaySetup.new(true, "Head & Shoulders", pstate, false, comp, neck, h, ep, sl, tp2, ls.i, bar_index, 0)
    if not s.active and pivL.size() >= 3 and pivH.size() >= 2 and enHs
        Pivot rs = pivL.get(0)
        Pivot head = pivL.get(1)
        Pivot ls = pivL.get(2)
        Pivot nh = pivH.get(1)
        Pivot rh = pivH.get(0)
        if head.p < rs.p and head.p < ls.p and f_near(rs.p, ls.p)
            float neck = f_proj(nh.i, nh.p, rh.i, rh.p, bar_index)
            float h = (nh.p + rh.p) * 0.5 - head.p
            if h > atrVal
                float comp = 65.0
                comp += close > neck ? 12.0 : 0.0
                comp += math.abs(close - neck) <= atrVal * armedAtr ? 18.0 : 0.0
                string pstate = close > neck + atrVal * brkAtr ? "FIRED" : math.abs(close - neck) <= atrVal * armedAtr ? "ARMED" : "FORMING"
                float ep = close
                float tp2 = neck + h
                float sl = ep - math.abs(tp2 - ep) * slPctTgt
                s := RelaySetup.new(true, "Inv H&S", pstate, true, comp, neck, h, ep, sl, tp2, ls.i, bar_index, 0)
    s

detectTriangleForm() =>
    RelaySetup s = EMPTY
    if pivH.size() >= 2 and pivL.size() >= 2 and enTriangle
        Pivot h1 = pivH.get(0)
        Pivot h2 = pivH.get(1)
        Pivot l1 = pivL.get(0)
        Pivot l2 = pivL.get(1)
        float uNow = f_proj(h2.i, h2.p, h1.i, h1.p, bar_index)
        float lNow = f_proj(l2.i, l2.p, l1.i, l1.p, bar_index)
        float base = math.abs(f_proj(h2.i, h2.p, h1.i, h1.p, l2.i) - f_proj(l2.i, l2.p, l1.i, l1.p, l2.i))
        bool conv = uNow > lNow and base > atrVal
        if conv
            float su = (h1.p - h2.p) / math.max(1, h1.i - h2.i)
            float slp = (l1.p - l2.p) / math.max(1, l1.i - l2.i)
            bool asc = math.abs(su) < close * 0.0003 and slp > 0
            bool desc = su < 0 and math.abs(slp) < close * 0.0003
            bool bullBreak = close > uNow + atrVal * brkAtr
            bool bearBreak = close < lNow - atrVal * brkAtr
            if bullBreak or (not bearBreak and (asc or su < 0))
                float comp = 60.0 + (base / atrVal > 2 ? 15 : 5)
                comp += math.abs(close - uNow) <= atrVal * armedAtr ? 15.0 : 0.0
                string pstate = bullBreak ? "FIRED" : math.abs(close - uNow) <= atrVal * armedAtr ? "ARMED" : "FORMING"
                float ep = close
                float tp2 = uNow + base
                float stop = lNow
                string nm = asc ? "Asc Triangle" : "Sym Triangle"
                s := RelaySetup.new(true, nm, pstate, true, comp, uNow, base, ep, stop, tp2, l2.i, bar_index, 0)
            else if bearBreak or desc
                float comp = 60.0 + (base / atrVal > 2 ? 15 : 5)
                comp += math.abs(close - lNow) <= atrVal * armedAtr ? 15.0 : 0.0
                string pstate = bearBreak ? "FIRED" : math.abs(close - lNow) <= atrVal * armedAtr ? "ARMED" : "FORMING"
                float ep = close
                float tp2 = lNow - base
                float stop = uNow
                string nm = desc ? "Desc Triangle" : "Sym Triangle"
                s := RelaySetup.new(true, nm, pstate, false, comp, lNow, base, ep, stop, tp2, l2.i, bar_index, 0)
    s

detectFlagForm() =>
    RelaySetup s = EMPTY
    if pivH.size() >= 2 and pivL.size() >= 2 and enFlag
        Pivot h1 = pivH.get(0)
        Pivot h2 = pivH.get(1)
        Pivot l1 = pivL.get(0)
        Pivot l2 = pivL.get(1)
        int sb = math.min(h2.i, l2.i)
        int span = bar_index - sb + 1
        float pole = span > 5 ? ta.highest(high, math.min(span, 160)) - ta.lowest(low, math.min(span, 160)) : 0.0
        float su = (h1.p - h2.p) / math.max(1, h1.i - h2.i)
        float slo = (l1.p - l2.p) / math.max(1, l1.i - l2.i)
        if pole > atrVal * 3.0
            if su < 0 and slo < 0
                float uB = f_proj(h2.i, h2.p, h1.i, h1.p, bar_index)
                float comp = 62.0
                comp += math.abs(close - uB) <= atrVal * armedAtr ? 20.0 : 0.0
                bool fired = close > uB + atrVal * brkAtr
                string pstate = fired ? "FIRED" : math.abs(close - uB) <= atrVal * armedAtr ? "ARMED" : "FORMING"
                float ep = close
                float tp2 = uB + pole
                float stop = f_proj(l2.i, l2.p, l1.i, l1.p, bar_index)
                s := RelaySetup.new(true, "Bull Flag", pstate, true, comp, uB, pole, ep, stop, tp2, sb, bar_index, 0)
            else if su > 0 and slo > 0
                float lB = f_proj(l2.i, l2.p, l1.i, l1.p, bar_index)
                float comp = 62.0
                comp += math.abs(close - lB) <= atrVal * armedAtr ? 20.0 : 0.0
                bool fired = close < lB - atrVal * brkAtr
                string pstate = fired ? "FIRED" : math.abs(close - lB) <= atrVal * armedAtr ? "ARMED" : "FORMING"
                float ep = close
                float tp2 = lB - pole
                float stop = f_proj(h2.i, h2.p, h1.i, h1.p, bar_index)
                s := RelaySetup.new(true, "Bear Flag", pstate, false, comp, lB, pole, ep, stop, tp2, sb, bar_index, 0)
    s

detectWedgeForm() =>
    RelaySetup s = EMPTY
    if pivH.size() >= 2 and pivL.size() >= 2 and enWedge
        Pivot h1 = pivH.get(0)
        Pivot h2 = pivH.get(1)
        Pivot l1 = pivL.get(0)
        Pivot l2 = pivL.get(1)
        float su = (h1.p - h2.p) / math.max(1, h1.i - h2.i)
        float slo = (l1.p - l2.p) / math.max(1, l1.i - l2.i)
        float uB = f_proj(h2.i, h2.p, h1.i, h1.p, bar_index)
        float lB = f_proj(l2.i, l2.p, l1.i, l1.p, bar_index)
        if uB > lB
            if su < 0 and slo < 0 and slo < su
                float comp = 58.0 + math.min(20.0, (uB - lB) / atrVal * 5)
                bool fired = close > uB + atrVal * brkAtr
                string pstate = fired ? "FIRED" : math.abs(close - uB) <= atrVal * armedAtr ? "ARMED" : "FORMING"
                float ep = close
                float tp2 = h2.p
                float stop = lB
                s := RelaySetup.new(true, "Falling Wedge", pstate, true, comp, uB, uB - lB, ep, stop, tp2, l2.i, bar_index, 0)
            else if su > 0 and slo > 0 and slo > su
                float comp = 58.0 + math.min(20.0, (uB - lB) / atrVal * 5)
                bool fired = close < lB - atrVal * brkAtr
                string pstate = fired ? "FIRED" : math.abs(close - lB) <= atrVal * armedAtr ? "ARMED" : "FORMING"
                float ep = close
                float tp2 = l2.p
                float stop = uB
                s := RelaySetup.new(true, "Rising Wedge", pstate, false, comp, lB, uB - lB, ep, stop, tp2, l2.i, bar_index, 0)
    s

f_pickBest(RelaySetup a, RelaySetup b) =>
    if not b.active
        a
    else if not a.active
        b
    else
        float sa = f_conf(a) + a.completion * 0.05 + (a.phase == "FIRED" ? 3 : a.phase == "ARMED" ? 2 : 0)
        float sb = f_conf(b) + b.completion * 0.05 + (b.phase == "FIRED" ? 3 : b.phase == "ARMED" ? 2 : 0)
        sb > sa ? b : a

